{
  "version": "2.13",
  "variables": {
    "bg-app": {
      "type": "color",
      "value": "#0f0f0f"
    },
    "bg-panel": {
      "type": "color",
      "value": "#141414"
    },
    "bg-elevated": {
      "type": "color",
      "value": "#1a1a1a"
    },
    "bg-card": {
      "type": "color",
      "value": "#1f1f1f"
    },
    "text-primary": {
      "type": "color",
      "value": "#ffffff"
    },
    "text-secondary": {
      "type": "color",
      "value": "#a0a0a0"
    },
    "text-muted": {
      "type": "color",
      "value": "#666666"
    },
    "accent": {
      "type": "color",
      "value": "#f97316"
    },
    "positive": {
      "type": "color",
      "value": "#22c55e"
    },
    "warning": {
      "type": "color",
      "value": "#eab308"
    },
    "danger": {
      "type": "color",
      "value": "#ef4444"
    },
    "info": {
      "type": "color",
      "value": "#3b82f6"
    },
    "radius": {
      "type": "number",
      "value": 10
    },
    "sidebar-width": {
      "type": "number",
      "value": 240
    },
    "spacing": {
      "type": "number",
      "value": 16
    }
  },
  "children": [
    {
      "id": "readme",
      "type": "note",
      "name": "HOW TO SEE ALL SCREENS",
      "x": 0,
      "y": 0,
      "width": 600,
      "height": 200,
      "fill": "$warning",
      "content": "This file maps ALL 20 CRM screens from components/crm.tsx.\n\nIn Pencil: View → Zoom to Fit (or scroll right/down).\nScreens start at Y=1200 in a 4-column grid.\n\nTo get pixel-perfect UI: Cmd+K → paste prompt from design/PENCIL-BRIEF.md section 3.\nSource code: components/crm.tsx (1368 lines, 17 exported pages)."
    },
    {
      "id": "sitemap",
      "type": "frame",
      "name": "CRM Sitemap — 20 Screens",
      "x": 640,
      "y": 0,
      "width": 900,
      "height": 1100,
      "fill": "$bg-panel",
      "layout": "vertical",
      "children": [
        {
          "id": "map-dashboard",
          "type": "text",
          "content": "1. Dashboard (/) — New Enrollments, Total Enrolled Debt, Client Deposits, Creditor Payments",
          "fill": "$text-secondary",
          "fontSize": 12
        },
        {
          "id": "map-finance-overview",
          "type": "text",
          "content": "2. Finance Overview (/finance) — Activos, NSF, On Hold, Waiting",
          "fill": "$text-secondary",
          "fontSize": 12
        },
        {
          "id": "map-client-deposits",
          "type": "text",
          "content": "3. Client Deposits (/finance/client-deposits) — Active, NSF, On Hold, Waiting",
          "fill": "$text-secondary",
          "fontSize": 12
        },
        {
          "id": "map-creditor-payments",
          "type": "text",
          "content": "4. Pagos al Acreedor (/finance/creditor-payments-overview) — Negocios Activos, Dinero Saliendo, Pagos en Rango, En Legal",
          "fill": "$text-secondary",
          "fontSize": 12
        },
        {
          "id": "map-revenue",
          "type": "text",
          "content": "5. Revenue (/finance/revenue) — Fees Agendados, Fees Cobrados, Pagos Cleared este mes, Commissions warning",
          "fill": "$text-secondary",
          "fontSize": 12
        },
        {
          "id": "map-alerts",
          "type": "text",
          "content": "6. Alertas Reconciliación (/finance/alerts) — En seguimiento, Medio, Riesgo Alto, Posible Broken",
          "fill": "$text-secondary",
          "fontSize": 12
        },
        {
          "id": "map-settlement-overview",
          "type": "text",
          "content": "7. Settlement Overview (/settlement) — Negociables, Settlements Activos, Alertas, Settlements Mes",
          "fill": "$text-secondary",
          "fontSize": 12
        },
        {
          "id": "map-creditor-status",
          "type": "text",
          "content": "8. Creditor Status (/settlement/creditor-status) — Status count cards (up to 12), Creditor Status",
          "fill": "$text-secondary",
          "fontSize": 12
        },
        {
          "id": "map-monthly",
          "type": "text",
          "content": "9. Settlements del Mes (/settlement/monthly) — Count, Deuda negociada, Monto, Ahorro",
          "fill": "$text-secondary",
          "fontSize": 12
        },
        {
          "id": "map-futures",
          "type": "text",
          "content": "10. Futuros (/settlement/futures) — Sin acuerdo, Con fondos, Negociables 55%, Cuentas futuras",
          "fill": "$text-secondary",
          "fontSize": 12
        },
        {
          "id": "map-negociables",
          "type": "text",
          "content": "11. Negociables (/settlement/negociables) — Clientes negociables, Con deudas listas, Escrow total, Deudas pendientes",
          "fill": "$text-secondary",
          "fontSize": 12
        },
        {
          "id": "map-not-possible",
          "type": "text",
          "content": "12. No Posibles (/settlement/not-possible) — S40, S50, REMOVEPEND, ADDPEND",
          "fill": "$text-secondary",
          "fontSize": 12
        },
        {
          "id": "map-broken",
          "type": "text",
          "content": "13. Rotos (/settlement/broken) — Settlements Rotos",
          "fill": "$text-secondary",
          "fontSize": 12
        },
        {
          "id": "map-plan",
          "type": "text",
          "content": "14. Settlement Plan (/settlement/plan) — Plan (monthly est, 55%, first settlement month)",
          "fill": "$text-secondary",
          "fontSize": 12
        },
        {
          "id": "map-sales",
          "type": "text",
          "content": "15. Sales (/sales) — Total Signed, First Payment, Missing, Completion Rate",
          "fill": "$text-secondary",
          "fontSize": 12
        },
        {
          "id": "map-retention",
          "type": "text",
          "content": "16. Retención (/retention) — Total Enrolled, Active Paying, Never Paid Left, Cancelled After Paying",
          "fill": "$text-secondary",
          "fontSize": 12
        },
        {
          "id": "map-settings",
          "type": "text",
          "content": "17. Settings (/settings) — ",
          "fill": "$text-secondary",
          "fontSize": 12
        },
        {
          "id": "map-nsf-tickets",
          "type": "text",
          "content": "18. NSF Tickets (/tickets/nsf) — Proposed tickets, Editable subject/content",
          "fill": "$text-secondary",
          "fontSize": 12
        },
        {
          "id": "map-csbo-tickets",
          "type": "text",
          "content": "19. CS/BO Alerts (/tickets/csbo) — ",
          "fill": "$text-secondary",
          "fontSize": 12
        },
        {
          "id": "map-tomorrow",
          "type": "text",
          "content": "20. Pagos Mañana (/payments/tomorrow) — Payment tables with totals",
          "fill": "$text-secondary",
          "fontSize": 12
        }
      ]
    },
    {
      "id": "import-prompt",
      "type": "prompt",
      "name": "FULL IMPORT PROMPT — Cmd+K",
      "x": 1600,
      "y": 0,
      "width": 560,
      "height": 500,
      "fill": "$bg-elevated",
      "content": "Import the COMPLETE Settlements CRM from this workspace.\n\nMUST READ ENTIRE FILE: components/crm.tsx (all 17 exported page functions).\nAlso: components/layout/sidebar.tsx, components/tickets/ticket-review.tsx, components/payments/tomorrow-payments.tsx, components/dashboard/kpi-card.tsx, components/ui/*.\n\nRecreate ALL 20 screens already wireframed in this .pen file with full visual fidelity:\nDashboard, Finance (5 pages), Settlement (8 pages), Sales, Retention, Settings, NSF Tickets, CS/BO Tickets, Pagos Mañana.\n\nUse dark theme variables. Improve clarity: section grouping, labels, mobile nav drawer."
    },
